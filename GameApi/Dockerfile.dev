FROM mcr.microsoft.com/dotnet/sdk:9.0

WORKDIR /src

# Cache: előbb csak csproj + restore
COPY DndApi.csproj ./
RUN dotnet restore

# A többi fájl (DEV-ben úgyis mountolsz, de buildhez kell)
COPY . .

# Kestrel 5000-en, minden interfészen
ENV ASPNETCORE_URLS=http://+:5000

# Windows+Docker bind mount esetén stabilabb watch viselkedés
ENV DOTNET_USE_POLLING_FILE_WATCHER=1
ENV DOTNET_WATCH_SUPPRESS_MSBUILD_INCREMENTALISM=1

EXPOSE 5000

CMD ["dotnet", "watch", "run", "--urls", "http://0.0.0.0:5000"]
